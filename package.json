{
  "name": "my-presence",
  "version": "1.0.0",
  "private": true,
  "description": "Premium Discord Rich Presence desktop application",
  "main": "dist-electron/main.js",
  "author": "OpenAI Codex",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "node -e \"const fs=require('fs'),p='public/assets/backgrounds';fs.mkdirSync(p,{recursive:true});if(fs.existsSync('default.mp4'))fs.copyFileSync('default.mp4',p+'/default.mp4')\" && npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"const fs=require('fs');if(fs.existsSync('electron/trayIcon.b64.txt'))fs.copyFileSync('electron/trayIcon.b64.txt','dist-electron/trayIcon.b64.txt')\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "start": "electron .",
    "icons": "node scripts/generate-icons.cjs",
    "pack": "npm run icons && npm run build && electron-builder --win --dir",
    "dist": "npm run icons && npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.mypresence.app",
    "productName": "MY Presence",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "default.mp4",
      "ic_app_logo.png",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "default.mp4",
      "dist/default.mp4",
      "dist/assets/backgrounds/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "ic_app_logo.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.19",
    "geist": "^1.7.2",
    "gifenc": "^1.0.3",
    "gifuct-js": "^2.1.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "electron": "^32.1.2",
    "electron-builder": "^26.15.3",
    "eslint": "^9.11.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}
